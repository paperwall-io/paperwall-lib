              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.articleSession.data": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.balance": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      },
