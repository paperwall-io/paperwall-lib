{
  "consumer": {
    "name": "paperwall-lib"
  },
  "interactions": [
    {
      "description": "a request for a non-existent article returns 404",
      "pending": false,
      "providerStates": [
        {
          "name": "no article exists"
        }
      ],
      "request": {
        "body": {
          "content": {
            "sessionId": null
          },
          "contentType": "application/json",
          "encoded": false
        },
        "generators": {
          "path": {
            "expression": "/articles/${articleId}/session",
            "type": "ProviderState"
          }
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ],
          "app-origin": [
            "embed"
          ],
          "app-site-session": [
            "valid-site-session-token"
          ]
        },
        "matchingRules": {
          "path": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          }
        },
        "method": "POST",
        "path": "/articles/non-existent-id/session"
      },
      "response": {
        "body": {
          "content": {
            "errors": [
              {
                "message": "Article not found"
              }
            ]
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "status": 404
      },
      "type": "Synchronous/HTTP"
    },
    {
      "description": "a request to create a new article session",
      "pending": false,
      "providerStates": [
        {
          "name": "an article exists"
        }
      ],
      "request": {
        "body": {
          "content": {
            "sessionId": null
          },
          "contentType": "application/json",
          "encoded": false
        },
        "generators": {
          "path": {
            "expression": "/articles/${articleId}/session",
            "type": "ProviderState"
          }
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ],
          "app-origin": [
            "embed"
          ],
          "app-site-session": [
            "valid-site-session-token"
          ]
        },
        "matchingRules": {
          "path": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          }
        },
        "method": "POST",
        "path": "/articles/pact-article-id/session"
      },
      "response": {
        "body": {
          "content": {
            "articleSession": {
              "article_id": "article-id",
              "data": {
                "has_purchased": true,
                "is_site_member": false,
                "pricing": {
                  "num_tickets": 0,
                  "threshold_value": 100
                }
              },
              "id": "session-id"
            },
            "balance": 0
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$.articleSession": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.articleSession.data": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.articleSession.data.pricing": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.balance": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      },
      "type": "Synchronous/HTTP"
    },
    {
      "description": "a request to rate a purchased article",
      "pending": false,
      "providerStates": [
        {
          "name": "an article exists with a purchased session"
        }
      ],
      "request": {
        "body": {
          "content": {
            "rating": 4
          },
