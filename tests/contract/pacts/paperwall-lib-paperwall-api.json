    {
      "description": "a request to retrieve an existing purchased session",
      "pending": false,
      "providerStates": [
        {
          "name": "an article exists with a purchased session"
        }
      ],
      "request": {
        "body": {
          "content": {
            "sessionId": "pact-session-id"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "generators": {
          "body": {
            "$.sessionId": {
              "expression": "${sessionId}",
              "type": "ProviderState"
            }
          },
          "path": {
            "expression": "/articles/${articleId}/session",
            "type": "ProviderState"
          }
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ],
          "app-origin": [
            "embed"
          ],
          "app-site-session": [
            "valid-site-session-token"
          ]
        },
        "matchingRules": {
          "body": {
            "$.sessionId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "path": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          }
        },
        "method": "POST",
        "path": "/articles/pact-article-id/session"
      },
      "response": {
        "body": {
          "content": {
            "articleSession": {
              "article_id": "article-id",
              "data": {
                "has_purchased": true
              },
              "id": "session-id"
            },
            "balance": 0
